# Copy to .env and fill in. .env is gitignored.

# Fireworks AI — https://fireworks.ai (key looks like fw_...)
FIREWORKS_API_KEY=
# Optional, for fine-tuning / deployments:
# FIREWORKS_ACCOUNT_ID=

# Daytona — https://app.daytona.io (key looks like dtn_...)
DAYTONA_API_KEY=
DAYTONA_API_URL=https://app.daytona.io/api
DAYTONA_TARGET=us

# Modal — no key in .env; run `python3 -m modal setup` (browser auth → ~/.modal.toml).
# CI only:
# MODAL_TOKEN_ID=
# MODAL_TOKEN_SECRET=

# HUD — https://hud.ai/project/api-keys
# HUD_API_KEY=
